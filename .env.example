OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

SURREAL_URL=ws://localhost:8000/rpc
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=kg
SURREAL_DB=world_anvil

# Enable embeddings for entity dedup and RAG chunk indexing (uses OpenAI API)
USE_EMBEDDINGS=true
EMBEDDING_DIM=1536
FUZZY_MATCH_THRESHOLD=85

# RAG chunking (smaller spans than extraction chunks)
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=6
